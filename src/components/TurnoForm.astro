---
const solicitudes = [
	'Soporte técnico de notebook o PC',
	'Problema con software o aplicaciones',
	'Problema de usuario, contraseña o accesos',
	'Configuración de equipos',
	'Cambio o entrega de notebook',
	'Cambio o entrega de celular',
	'Cambio de cargador',
	'Impresoras',
	'Cámaras de seguridad',
	'Red / Internet / Wi-Fi',
	'Instalación de programas',
	'Otro',
];

const equipos = ['Notebook', 'PC de escritorio', 'Celular', 'Impresora'];

const horarios = [
	'09:30',
	'10:00',
	'10:30',
	'11:00',
	'11:30',
	'12:00',
	'12:30',
	'14:00',
	'14:30',
	'15:00',
	'15:30',
	'16:00',
	'16:30',
];
---

<section class="form-section" aria-labelledby="form-title">
	<div class="form-card">
		<div class="form-heading">
			<p class="eyebrow">Turno presencial con el Área de Sistemas</p>
			<h2 id="form-title">Solicitud de asistencia</h2>
		</div>

		<form id="turno-form" novalidate>
			<div class="form-grid">
				<label class="field">
					<span>Nombre y apellido *</span>
					<input type="text" name="nombre" autocomplete="name" minlength="3" maxlength="80" required />
					<small data-error-for="nombre"></small>
				</label>

				<label class="field">
					<span>Correo *</span>
					<input type="email" name="correo" autocomplete="email" maxlength="120" required />
					<small data-error-for="correo"></small>
				</label>

				<label class="field">
					<span>CUIL / CUIT *</span>
					<input
						type="text"
						name="cuil"
						inputmode="numeric"
						autocomplete="off"
						pattern="[0-9\\-\\s]{11,15}"
						maxlength="15"
						required
					/>
					<small data-error-for="cuil"></small>
				</label>

				<label class="field">
					<span>Tipo de solicitud *</span>
					<select name="tipoSolicitud" required>
						<option value="">Seleccionar</option>
						{solicitudes.map((solicitud) => <option value={solicitud}>{solicitud}</option>)}
					</select>
					<small data-error-for="tipoSolicitud"></small>
				</label>

				<label class="field">
					<span>Equipo involucrado *</span>
					<select name="equipo" required>
						<option value="">Seleccionar</option>
						{equipos.map((equipo) => <option value={equipo}>{equipo}</option>)}
					</select>
					<small data-error-for="equipo"></small>
				</label>

				<label class="field">
					<span>Fecha del turno *</span>
					<input type="date" name="fechaTurno" required />
					<small data-error-for="fechaTurno"></small>
				</label>

				<label class="field">
					<span>Hora del turno *</span>
					<select name="horaTurno" required>
						<option value="">Seleccionar horario</option>
						{horarios.map((horario) => <option value={horario}>{horario}</option>)}
					</select>
					<small data-error-for="horaTurno"></small>
				</label>

				<label class="field field-full">
					<span>Descripción opcional</span>
					<textarea name="descripcion" rows="3" maxlength="600"></textarea>
					<small data-error-for="descripcion"></small>
				</label>
			</div>

			<div class="form-actions">
				<p id="form-status" class="form-status" role="status" aria-live="polite"></p>
				<button id="submit-button" type="submit">Confirmar turno</button>
			</div>
		</form>
	</div>
</section>
