---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

const linktreeUrl = 'https://linktr.ee/sistemasssato';
const turnosUrl = 'https://mda-sistemas-ssato.vercel.app/turnos';
const qrBase = 'https://api.qrserver.com/v1/create-qr-code/?size=220x220&margin=12&data=';
---

<Layout>
	<main class="flyer-page">
		<div class="print-actions" aria-hidden="true">
			<button type="button" onclick="window.print()">Imprimir folleto</button>
		</div>

		<section class="flyer-sheet" aria-label="Folleto Mesa de Ayuda SSATO">
			<header class="flyer-header">
				<img class="flyer-logo-ssato" src="/logo-ssato-transparente.png" alt="Sistemas SSATO" width="520" height="210" />
				<div>
					<p>Area de Sistemas SSATO</p>
					<h1>Mesa de Ayuda y Portal de Recursos</h1>
				</div>
			</header>

			<section class="flyer-hero">
				<div>
					<p class="flyer-kicker">Importante</p>
					<h2>Todos los pedidos de asistencia requieren turno previo.</h2>
					<p>
						Para soporte informatico, equipos, accesos, software, impresoras o conectividad,
						ingresa al portal y solicita tu turno desde la Mesa de Ayuda SSATO.
					</p>
				</div>
				<div class="flyer-contact-box">
					<span class="flyer-contact-label">Horario</span>
					<strong>Atencion</strong>
					<span>Lunes a viernes</span>
					<b>9:30 a 16:30 h</b>
				</div>
			</section>

			<section class="flyer-grid">
				<article class="flyer-card">
					<div>
						<p class="flyer-kicker">Portal</p>
						<h3>Linktree Sistemas SSATO</h3>
						<p>
							Desde el Linktree accedes a los recursos principales del area: turnos,
							consultas, enlaces utiles y canales oficiales.
						</p>
					</div>
					<img
						class="flyer-qr"
						src={`${qrBase}${encodeURIComponent(linktreeUrl)}`}
						alt="QR del Linktree de Sistemas SSATO"
						width="136"
						height="136"
					/>
					<a href={linktreeUrl}>{linktreeUrl}</a>
				</article>

				<article class="flyer-card">
					<div>
						<p class="flyer-kicker">Turnos</p>
						<h3>Mesa de Ayuda SSATO</h3>
						<p>
							Completa tus datos, elegi fecha y horario disponible. Al confirmar, recibiras
							el numero de ticket por correo.
						</p>
					</div>
					<img
						class="flyer-qr"
						src={`${qrBase}${encodeURIComponent(turnosUrl)}`}
						alt="QR para solicitar turno en Mesa de Ayuda SSATO"
						width="136"
						height="136"
					/>
					<a href={turnosUrl}>{turnosUrl}</a>
				</article>
			</section>

			<section class="flyer-steps">
				<h2>Como usarlo</h2>
				<ol>
					<li>
						<strong>Escanea el QR o entra al Linktree.</strong>
						<span>Desde ahi vas a encontrar los accesos oficiales de Sistemas SSATO.</span>
					</li>
					<li>
						<strong>Selecciona Mesa de Ayuda.</strong>
						<span>Todos los pedidos presenciales o de gestion deben iniciarse con turno.</span>
					</li>
					<li>
						<strong>Completa el formulario.</strong>
						<span>Indica nombre, correo, CUIL/CUIT, reparticion, equipo y motivo.</span>
					</li>
					<li>
						<strong>Revisa tu correo.</strong>
						<span>Recibiras la confirmacion con el ticket del turno registrado.</span>
					</li>
				</ol>
			</section>

			<footer class="flyer-footer">
				<div>
					<strong>sistemasssato@gmail.com</strong>
					<span>WhatsApp: +54 11 4147 8977</span>
				</div>
				<p>Área de Sistemas SSATO - Mesa de Ayuda</p>
			</footer>
		</section>
	</main>
</Layout>

<style>
	:global(body:has(.flyer-page)) {
		background:
			radial-gradient(circle at 18% 12%, rgba(0, 185, 214, 0.18), transparent 28rem),
			radial-gradient(circle at 82% 20%, rgba(0, 145, 214, 0.12), transparent 26rem),
			linear-gradient(135deg, #edf9ff 0%, #dff7ff 48%, #eefcff 100%);
		color: #eef6ff;
	}

	.flyer-page {
		display: grid;
		place-items: start center;
		min-height: 100vh;
		padding: 24px;
		color: #eef6ff;
		font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
	}

	.print-actions {
		width: min(210mm, 100%);
		margin-bottom: 12px;
		text-align: right;
	}

	.print-actions button {
		width: auto;
		min-height: 40px;
		border: 1px solid rgba(114, 227, 196, 0.34);
		background: linear-gradient(135deg, #008cc9, #00a887);
		color: #ffffff;
		box-shadow: 0 14px 28px rgba(0, 127, 186, 0.26);
	}

	.flyer-sheet {
		width: 210mm;
		min-height: 297mm;
		display: flex;
		flex-direction: column;
		gap: 16px;
		position: relative;
		overflow: hidden;
		background:
			linear-gradient(rgba(6, 19, 33, 0.7), rgba(6, 19, 33, 0.78)),
			url('/exterior-ministerio.png') center center / cover no-repeat,
			linear-gradient(135deg, #07355a 0%, #072844 48%, #061f34 100%);
		padding: 16mm;
		border: 1px solid rgba(114, 227, 196, 0.24);
		box-shadow: 0 24px 60px rgba(0, 0, 0, 0.34);
	}

	.flyer-sheet::before {
		position: absolute;
		top: 0;
		right: 0;
		left: 0;
		height: 8mm;
		background: linear-gradient(90deg, #00d9ff, #008cc9, #00a6ff);
		content: '';
	}

	.flyer-sheet::after {
		position: absolute;
		right: -38mm;
		bottom: -42mm;
		width: 96mm;
		height: 96mm;
		border: 1px solid rgba(114, 227, 196, 0.2);
		border-radius: 999px;
		background: radial-gradient(circle, rgba(0, 168, 135, 0.16), transparent 66%);
		content: '';
		pointer-events: none;
	}

	.flyer-header {
		display: grid;
		grid-template-columns: 340px 1fr;
		gap: 24px;
		align-items: center;
		position: relative;
		z-index: 1;
		border: 1px solid rgba(0, 217, 255, 0.28);
		border-radius: 12px;
		background: rgba(238, 250, 255, 0.92);
		padding: 16px 18px;
		margin-top: 4mm;
		backdrop-filter: blur(10px);
		box-shadow: 0 18px 40px rgba(0, 0, 0, 0.2);
	}

	.flyer-logo-ssato {
		width: min(340px, 100%);
		max-height: 138px;
		object-fit: contain;
		filter: drop-shadow(0 14px 26px rgba(0, 140, 201, 0.16));
	}

	.flyer-header p,
	.flyer-kicker {
		margin: 0 0 3px;
		color: #008cc9;
		font-size: 0.78rem;
		font-weight: 950;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.flyer-header h1 {
		margin: 0;
		color: #071322;
		font-size: 2rem;
		line-height: 1.05;
	}

	.flyer-hero {
		display: grid;
		grid-template-columns: 1fr 210px;
		gap: 16px;
		align-items: stretch;
		position: relative;
		z-index: 1;
		border: 1px solid rgba(0, 140, 201, 0.22);
		border-radius: 12px;
		background:
			linear-gradient(135deg, rgba(0, 217, 255, 0.18), rgba(0, 140, 201, 0.12)),
			rgba(248, 253, 255, 0.96);
		padding: 18px;
		box-shadow: 0 18px 42px rgba(0, 0, 0, 0.2);
	}

	.flyer-hero h2,
	.flyer-steps h2 {
		margin: 0;
		color: #071322;
		font-size: 1.55rem;
		line-height: 1.12;
	}

	.flyer-hero p:not(.flyer-kicker),
	.flyer-card p,
	.flyer-steps span {
		margin: 8px 0 0;
		color: #284057;
		font-size: 1rem;
		font-weight: 650;
		line-height: 1.42;
	}

	.flyer-contact-box {
		display: grid;
		align-content: center;
		border: 1px solid rgba(0, 168, 135, 0.28);
		border-radius: 10px;
		background: #ffffff;
		padding: 12px;
		text-align: center;
		box-shadow: inset 0 0 0 4px rgba(0, 168, 135, 0.06);
	}

	.flyer-contact-label {
		justify-self: center;
		width: fit-content;
		border: 1px solid rgba(0, 168, 135, 0.28);
		border-radius: 999px;
		background: rgba(0, 168, 135, 0.12);
		color: #00705d;
		padding: 3px 8px;
		font-size: 0.72rem;
		font-weight: 950;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.flyer-contact-box strong,
	.flyer-contact-box b {
		font-size: 1.25rem;
		line-height: 1.1;
	}

	.flyer-contact-box span,
	.flyer-contact-box small {
		margin-top: 5px;
		color: #40586e;
		font-weight: 750;
	}

	.flyer-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 14px;
	}

	.flyer-card {
		display: grid;
		grid-template-columns: 1fr 136px;
		gap: 12px;
		align-items: center;
		position: relative;
		z-index: 1;
		border: 1px solid rgba(0, 140, 201, 0.22);
		border-radius: 12px;
		background: rgba(248, 253, 255, 0.96);
		padding: 16px;
		box-shadow: 0 16px 34px rgba(0, 0, 0, 0.18);
	}

	.flyer-card::before {
		position: absolute;
		top: 0;
		left: 0;
		width: 7px;
		height: 100%;
		border-radius: 12px 0 0 12px;
		background: linear-gradient(180deg, #00d9ff, #008cc9);
		content: '';
	}

	.flyer-card h3 {
		margin: 0;
		color: #071322;
		font-size: 1.35rem;
		line-height: 1.1;
	}

	.flyer-card a {
		grid-column: 1 / -1;
		overflow-wrap: anywhere;
		border-top: 1px solid rgba(0, 127, 186, 0.18);
		padding-top: 9px;
		color: #008cc9;
		font-size: 0.88rem;
		font-weight: 900;
		text-decoration: none;
	}

	.flyer-qr {
		width: 136px;
		height: 136px;
		border: 1px solid rgba(0, 127, 186, 0.24);
		border-radius: 10px;
		background: #ffffff;
		padding: 5px;
		box-shadow: 0 12px 24px rgba(0, 127, 186, 0.14);
	}

	.flyer-steps {
		position: relative;
		z-index: 1;
		border: 1px solid rgba(0, 140, 201, 0.22);
		border-radius: 12px;
		background: rgba(248, 253, 255, 0.96);
		padding: 14px 16px;
		box-shadow: 0 16px 34px rgba(0, 0, 0, 0.18);
	}

	.flyer-steps ol {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 12px 16px;
		margin: 12px 0 0;
		padding: 0;
		list-style: none;
		counter-reset: steps;
	}

	.flyer-steps li {
		position: relative;
		min-height: 82px;
		border-left: 5px solid #008cc9;
		border-radius: 8px;
		background:
			linear-gradient(90deg, rgba(0, 217, 255, 0.12), rgba(255, 255, 255, 0.94)),
			#ffffff;
		padding: 10px 10px 10px 48px;
		counter-increment: steps;
	}

	.flyer-steps li::before {
		position: absolute;
		top: 10px;
		left: 10px;
		display: grid;
		place-items: center;
		width: 28px;
		height: 28px;
		border: 1px solid rgba(0, 168, 135, 0.3);
		border-radius: 999px;
		background: linear-gradient(135deg, #00d9ff, #008cc9);
		color: #ffffff;
		content: counter(steps);
		font-weight: 950;
	}

	.flyer-steps strong,
	.flyer-steps span {
		display: block;
	}

	.flyer-steps strong {
		color: #071322;
		font-size: 0.95rem;
	}

	.flyer-steps span {
		margin-top: 4px;
		font-size: 0.86rem;
	}

	.flyer-footer {
		margin-top: auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		position: relative;
		z-index: 1;
		border: 1px solid rgba(0, 217, 255, 0.24);
		border-radius: 12px;
		background: rgba(7, 19, 34, 0.86);
		padding: 12px 14px;
		color: #eef6ff;
		font-size: 0.9rem;
		font-weight: 850;
	}

	.flyer-footer span {
		color: #b8c8d8;
	}

	.flyer-footer strong,
	.flyer-footer span {
		display: block;
	}

	.flyer-footer p {
		margin: 0;
		text-align: right;
	}

	@media (max-width: 820px) {
		.flyer-page {
			padding: 12px;
		}

		.flyer-sheet {
			width: 100%;
			min-height: auto;
			padding: 18px;
		}

		.flyer-header {
			grid-template-columns: 1fr;
			gap: 12px;
		}

		.flyer-logo-ssato {
			width: min(320px, 100%);
			max-height: 130px;
		}

		.flyer-header h1 {
			font-size: 1.75rem;
		}

		.flyer-hero,
		.flyer-grid,
		.flyer-card,
		.flyer-steps ol {
			grid-template-columns: 1fr;
		}

		.flyer-card {
			justify-items: start;
		}

		.flyer-footer {
			display: grid;
			align-items: start;
		}

		.flyer-footer p {
			text-align: left;
		}
	}

	@page {
		size: A4;
		margin: 0;
	}

	@media print {
		:global(html),
		:global(body:has(.flyer-page)) {
			width: 210mm;
			min-height: 297mm;
			background: #071322;
		}

		.print-actions {
			display: none;
		}

		.flyer-page {
			display: block;
			min-height: auto;
			padding: 0;
		}

		.flyer-sheet {
			width: 210mm;
			min-height: 297mm;
			box-shadow: none;
			page-break-after: avoid;
		}

		.flyer-card,
		.flyer-hero,
		.flyer-steps,
		.flyer-steps li {
			break-inside: avoid;
		}
	}
</style>
