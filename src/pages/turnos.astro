---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import TurnoForm from '../components/TurnoForm.astro';
import Footer from '../components/Footer.astro';
import FloatingWhatsApp from '../components/FloatingWhatsApp.astro';
import '../styles/global.css';
---

<Layout>
	<Navbar />
	<main class="site-shell turnos-shell">
		<section class="turnos-intro" aria-labelledby="turnos-title">
			<p class="eyebrow">Sistemas SSATO</p>
			<h1 id="turnos-title">Turno de mesa de ayuda</h1>
			<p>
				Todos los pedidos requieren turno previo. Completá el formulario para solicitar
				asistencia informática.
			</p>
		</section>
		<TurnoForm />
	</main>
	<Footer />
	<FloatingWhatsApp />
	<script type="module" src="/src/scripts/turnera.js"></script>
	<script type="module" src="/src/scripts/ui-controls.js"></script>
</Layout>
